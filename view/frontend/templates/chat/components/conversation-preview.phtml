<?php

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var ViewModelRegistry $viewModels */
/** @var Escaper $escaper */
/** @var HeroiconsOutline $heroicons */

$heroicons = $viewModels->require(HeroiconsOutline::class);
?>
<li
    class="livechat-conversation-wrapper"
>
    <button
        class="livechat-conversation"
        :aria-label="getConversationLabel(conversation)"
        @click="openConversation(conversation.id)"
    >
        <div class="livechat-conversation-title">
            <p class="title" x-html="formatConversationTitle(conversation.created_at)"></p>
            <span class="last-message-date" x-text="formatLastMessageDate(conversation)"></span>
        </div>
        <div class="livechat-conversation-preview">
            <p class="preview-message" x-text="formatConversationMessagePreview(conversation)"></p>
            <template x-if="conversation.total_unread">
                <div class="unread" x-text="conversation.total_unread >= 10 ? '9+' : conversation.total_unread"></div>
            </template>
        </div>
    </button>
</li>

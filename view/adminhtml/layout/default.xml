<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="mercure_script" />
    <body>
        <referenceContainer name="before.body.end">
            <block class="Magento\Backend\Block\Template"
                   name="livechat.widget"
                   template="MaxStan_LiveChat::chat/wrapper.phtml"
            >
                <block class="Magento\Backend\Block\Template"
                       name="livechat.components.button"
                       as="button"
                       template="MaxStan_LiveChat::chat/components/button.phtml" />
            </block>
        </referenceContainer>
    </body>
</page>
